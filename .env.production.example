# ============================================================================
# Bridge API — Production env template
# ----------------------------------------------------------------------------
# Copie para .env na VPS (em /opt/bridge/.env) e preencha os SEGREDOS.
# Gere segredos fortes:
#   APP_SECRET_KEY:  openssl rand -hex 32
#   ENCRYPTION_KEY:  openssl rand -hex 32   (precisa ter 64 chars hex = 32 bytes)
#   senhas de DB:    openssl rand -base64 24
# NUNCA versione este arquivo já preenchido. .env está no .gitignore.
# ============================================================================

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=__TROCAR__openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Origens permitidas pelo CORS (front). Separe por vírgula, sem espaços.
CORS_ORIGINS=https://bridgeapi.gsvtech.com.br

# ── Network / build ─────────────────────────────────────────────────────────
# nginx roda no host e faz o proxy: expõe os containers só em localhost.
BIND_IP=127.0.0.1
# URL pública do backend — é "assada" no bundle do front no momento do build.
# Se mudar, precisa rebuildar o frontend.
NEXT_PUBLIC_API_URL=https://bridgeapiback.gsvtech.com.br

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Host = nome do container (postgres), pois tudo roda na mesma rede compose.
POSTGRES_USER=bridge
POSTGRES_PASSWORD=__TROCAR__senha_forte_postgres
POSTGRES_DB=bridgeapi
DATABASE_URL=postgresql+asyncpg://bridge:__TROCAR__senha_forte_postgres@postgres:5432/bridgeapi

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_USER=bridge
MONGO_PASSWORD=__TROCAR__senha_forte_mongo
MONGO_DB=bridgelogs
MONGO_URL=mongodb://bridge:__TROCAR__senha_forte_mongo@mongo:27017/bridgelogs?authSource=admin

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=__TROCAR__senha_forte_redis
REDIS_URL=redis://:__TROCAR__senha_forte_redis@redis:6379/0

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT_RPM=60

# ── Log Retention ───────────────────────────────────────────────────────────
LOG_RETENTION_HOURS=24

# ── Encryption (criptografa as master keys das APIs em repouso) ─────────────
# 32 bytes em hex (64 chars). NÃO reutilize a key de dev. Trocar = perder
# acesso aos segredos já criptografados no banco.
ENCRYPTION_KEY=__TROCAR__openssl_rand_hex_32
