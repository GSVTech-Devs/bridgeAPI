# ====================
# Application
# ====================
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ====================
# PostgreSQL
# ====================
POSTGRES_USER=bridge
POSTGRES_PASSWORD=bridge
POSTGRES_DB=bridgeapi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://bridge:bridge@localhost:5432/bridgeapi

# ====================
# MongoDB
# ====================
MONGO_USER=bridge
MONGO_PASSWORD=bridge
MONGO_DB=bridgelogs
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_URL=mongodb://bridge:bridge@localhost:27017/bridgelogs?authSource=admin

# ====================
# Redis
# ====================
REDIS_PASSWORD=bridge
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:bridge@localhost:6379/0

# ====================
# Rate Limiting (defaults)
# ====================
RATE_LIMIT_DEFAULT_RPM=60

# ====================
# Log Retention
# ====================
LOG_RETENTION_HOURS=24

# ====================
# Encryption
# ====================
# 32-byte hex key for encrypting API master keys at rest
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-key-here
