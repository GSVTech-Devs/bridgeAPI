# =============================================================================
# Bridge API — Environment Variables (exemplo)
# Copie para .env e ajuste os valores
# =============================================================================

# Application
APP_ENV=development
APP_SECRET_KEY=mude-isso-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://bridge:bridge@localhost:5432/bridgeapi

# MongoDB
MONGO_URL=mongodb://bridge:bridge@localhost:27017/bridgelogs?authSource=admin
MONGO_DB=bridgelogs

# Redis
REDIS_URL=redis://:bridge@localhost:6379/0

# Rate limiting (requests por minuto por chave)
RATE_LIMIT_DEFAULT_RPM=60

# Retenção de logs (horas)
LOG_RETENTION_HOURS=24

# Encryption key — 64 chars hex
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=sua-chave-de-64-chars-hex-aqui
